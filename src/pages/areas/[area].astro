---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CtaBand from "../../components/CtaBand.astro";
import Icon from "../../components/Icon.astro";
import { business } from "../../data/site";
import { areaPages } from "../../data/areas";
import { serviceSchema, breadcrumbList } from "../../data/schema";

export function getStaticPaths() {
  return areaPages.map((area) => ({
    params: { area: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;

const jsonLd = [
  serviceSchema({
    name: `Plumbing Services in ${area.city}, NH`,
    description: area.seo.description,
    path: `/areas/${area.slug}`,
    areaServed: area.city,
  }),
  breadcrumbList([{ name: `Plumber in ${area.city}, NH`, path: `/areas/${area.slug}` }]),
];
---

<BaseLayout title={area.seo.title} description={area.seo.description} ogImage={area.hero.image} jsonLd={jsonLd}>
  <Hero
    heading={area.hero.heading}
    subheading={area.hero.sub}
    image={area.hero.image}
    imageSrcset={area.hero.imageSrcset}
    imageAlt={area.hero.imageAlt}
  />

  <section class="section surface-cream">
    <div class="container area-intro">
      <div class="area-intro__content">
        <h2>{area.intro.heading}</h2>
        <p class="lead">{area.intro.body}</p>
        <div class="btn-group">
          <a href={business.bookingUrl} class="btn btn--gold"><Icon name="calendar" /> Book Appointment</a>
        </div>
      </div>
      <div class="area-intro__media">
        <img src={area.intro.image} srcset={area.intro.imageSrcset} sizes="(max-width: 900px) 90vw, 45vw" alt={area.intro.imageAlt} loading="lazy" />
      </div>
    </div>

    <div class="container area-body">
      <article class="area-body__main rich-text" set:html={area.bodyHtml} />

      <aside class="area-body__aside">
        <div class="aside-card">
          <p class="aside-card__eyebrow">Need a plumber in {area.city}?</p>
          <h2 class="aside-card__title">Schedule your service</h2>
          <p class="aside-card__text">
            Friendly, licensed plumbers ready to help {area.city} homeowners — fast.
          </p>
          <ul class="check-list aside-card__list">
            <li><Icon name="shield-check" /> Licensed &amp; insured team</li>
            <li><Icon name="tag" /> Upfront, honest pricing</li>
            <li><Icon name="clock" /> Fast, same-day response</li>
          </ul>
          <div class="aside-card__actions">
            <a href={business.bookingUrl} class="btn btn--gold"><Icon name="calendar" /> Book Online</a>
            <a href={business.navPhoneTel} class="btn btn--outline"><Icon name="phone" /> {business.navPhone}</a>
          </div>
          <p class="aside-card__rating">
            <span class="aside-card__stars">★★★★★</span> 4.9 · {business.reviewCount} Google reviews
          </p>
        </div>
      </aside>
    </div>
  </section>

  <CtaBand heading={area.cta.heading} body={area.cta.body} />
</BaseLayout>

<style>
  .area-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
    margin-bottom: var(--section-md);
  }
  .area-intro__content > * + * { margin-top: 1.1rem; }
  .area-intro__media img {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-hover);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  /* ---- long-form body + sticky CTA sidebar ---- */
  .area-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(18rem, 28%, 21rem);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }
  .area-body__main { max-width: 44rem; }

  .area-body__aside { position: sticky; top: calc(var(--header-h) + 1.25rem); }
  .aside-card {
    background: var(--white);
    border: 1px solid #00000012;
    border-top: 4px solid var(--gold-500);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: clamp(1.5rem, 2.5vw, 2rem);
  }
  .aside-card__eyebrow {
    font-family: var(--font-script);
    font-size: 1.6rem;
    line-height: 1;
    color: var(--color-gold-deep);
  }
  .aside-card__title {
    font-size: var(--fs-h4);
    color: var(--ink-900);
    margin-top: 0.35rem;
  }
  .aside-card__text {
    margin-top: 0.6rem;
    font-size: var(--fs-body-sm);
    color: var(--on-cream-muted);
  }
  .aside-card__list { margin: 1.25rem 0; font-size: var(--fs-body-sm); }
  .aside-card__list li { font-weight: 600; }
  .aside-card__actions { display: grid; gap: 0.6rem; }
  .aside-card__actions .btn { width: 100%; }
  .aside-card__rating {
    margin-top: 1.1rem;
    text-align: center;
    font-weight: 700;
    font-size: var(--fs-body-sm);
    color: var(--on-cream-muted);
  }
  .aside-card__stars { color: var(--color-gold); letter-spacing: 1px; }

  @media (max-width: 900px) {
    .area-intro { grid-template-columns: 1fr; }
    .area-body { grid-template-columns: 1fr; }
    .area-body__main { max-width: none; }
    .area-body__aside { position: static; }
  }
</style>
