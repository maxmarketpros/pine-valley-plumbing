---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import Marquee from "../components/Marquee.astro";
import TrustBadges from "../components/TrustBadges.astro";
import Testimonials from "../components/Testimonials.astro";
import HomeCtaBand from "../components/HomeCtaBand.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Icon from "../components/Icon.astro";
import RealWorkLabs from "../components/RealWorkLabs.astro";
import { business } from "../data/site";
import { plumberSchema, webSiteSchema, faqPageSchema } from "../data/schema";

const title = "Expert Master Plumber in Merrimack, NH | Pine Valley Plumbing";
const description =
  "Choose Pine Valley Plumbing for trusted, expert plumbing services in Merrimack, NH. We handle emergencies and installations with care and precision.";

const marqueeItems = [
  "Fast service", "Expert work", "Licensed master", "Gas certified", "Honest pricing",
  "Done right", "No shortcuts", "Visible care", "Hidden precision", "Always available",
];

const testimonials = [
  { quote: "Fast, professional, and honest.", location: "Merrimack, NH" },
  { quote: "Showed up on time and did great work.", location: "Bedford, NH" },
  { quote: "Best plumbing company we've used.", location: "Nashua, NH" },
];

// SEO services grid (matches source "pv-seo" block); img = base name in
// public/images/, reusing each service page's own photo
const seoServices = [
  ["Emergency Plumbing", "Burst pipes, backups, no hot water—call anytime for fast help.", "Emergency Plumbing Services", "/emergency-plumber-merrimack-nh", "phone", "relume-653300"],
  ["Drain Cleaning", "Clear clogs the right way—no shortcuts, no pipe damage.", "Drain Cleaning Services", "/drain-cleaning-merrimack-nh", "droplet", "relume-653303"],
  ["Water Heater Installation", "New tank or tankless systems installed cleanly, safely, and to code.", "Water Heater Installation", "/water-heater-installation-merrimack-nh", "flame", "relume-653305"],
  ["Water Heater Repair", "Diagnostics + real repairs so you’re not stuck with cold showers.", "Water Heater Repair", "/water-heater-repair-merrimack-nh", "thermometer", "relume-653360"],
  ["Gas Line Services", "Gas piping work done by a certified professional—safety first.", "Gas Line Services", "/gas-line-services-merrimack-nh", "shield-check", "relume-653349"],
  ["Pipe Repair & Leak Fixes", "Stop leaks, protect your home, and prevent bigger failures.", "Pipe Repair Services", "/pipe-repair-merrimack-nh", "wrench", "relume-653317"],
  ["Kitchen Plumbing", "Faucets, sinks, dishwasher hookups, and kitchen upgrades done right.", "Kitchen Plumbing Services", "/kitchen-plumbing-merrimack-nh", "utensils", "relume-653281"],
  ["Bathroom Remodeling", "Remodel plumbing for showers, tubs, toilets, and full bathroom upgrades.", "Bathroom Remodeling Services", "/bathroom-remodeling-merrimack-nh", "shower-head", "relume-653344"],
  ["Toilet Installation", "New installs or replacements—sealed, leveled, and tested.", "Toilet Installation Services", "/toilet-installation-merrimack-nh", "droplet", "relume-653333"],
  ["Garbage Disposal Installation", "Clean installs with proper connections and leak checks.", "Garbage Disposal Installation", "/garbage-disposal-installation-merrimack-nh", "trash", "relume-653336"],
  ["Flood Prevention", "Sump pumps & backflow protection to help keep basements dry.", "Water & Flood Prevention Systems", "/sump-pump-backflow-merrimack-nh", "waves", "relume-653352"],
];

const serviceBadges = ["Emergency Response", "Drain & Sewer Issues", "Water Heaters", "Gas Line Services", "Remodel Plumbing", "Leak & Pipe Repair"];

const faqs = [
  { q: "Do you offer emergency service?", a: "Yes. We handle emergency plumbing calls and come as fast as we can. Call (603) 339-6732 anytime you need us. We understand that plumbing problems don't follow business hours." },
  { q: "What areas do you service?", a: "We're based in Merrimack, New Hampshire and service the surrounding areas. That includes Nashua, Amherst, Hillsborough County, and beyond. Call to confirm we reach your location." },
  { q: "Are you licensed?", a: "I'm a master plumber with a gas license. Thirteen years in the trade and every job meets code. You can trust the work is done right." },
  { q: "Why take so much time?", a: "Rushing leads to problems. We do it right the first time, whether it's visible or hidden in the walls. That's how I was taught and that's how we work." },
];
---

<BaseLayout title={title} description={description} bodyClass="page-home" ogImage="/images/van-hero-og.jpg" jsonLd={[plumberSchema, webSiteSchema, faqPageSchema(faqs)]}>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      imagesrcset="/images/van-hero-p-500.webp 500w, /images/van-hero-p-800.webp 800w, /images/van-hero-p-1080.webp 1080w, /images/van-hero-p-1600.webp 1600w"
      imagesizes="100vw"
    />
  </Fragment>

  <HomeHero />

  <TrustBadges />

  <Marquee items={marqueeItems} />

  <Testimonials items={testimonials} />

  <!-- About / Go-to plumber -->
  <section class="section surface-night">
    <div class="container about-dark">
      <div class="about-dark__media">
        <img
          src="/images/van-forest-p-1080.webp"
          srcset="/images/van-forest-p-500.webp 500w, /images/van-forest-p-800.webp 800w, /images/van-forest-p-1080.webp 1080w, /images/van-forest-p-1600.webp 1600w"
          sizes="(max-width: 900px) 92vw, 44vw"
          width="1600"
          height="905"
          alt="Pine Valley Plumbing service van parked in a New Hampshire pine forest at dusk"
          loading="lazy"
        />
      </div>
      <div class="about-dark__content">
        <span class="eyebrow">Your Neighborhood</span>
        <h2>Go-To Plumber</h2>
        <p class="lead">At Pine Valley Plumbing, we're committed to honest recommendations, quality workmanship, and treating your home like our own.</p>
        <ul class="about-dark__list">
          <li><span class="about-dark__check"><Icon name="check" /></span> No upselling.</li>
          <li><span class="about-dark__check"><Icon name="check" /></span> No surprises.</li>
          <li><span class="about-dark__check"><Icon name="check" /></span> Just plumbing done right.</li>
        </ul>
        <div class="btn-group"><a href="/about-pine-valley-plumbing-merrimack-nh" class="btn btn--outline">About Us</a></div>
      </div>
    </div>
  </section>

  <HomeCtaBand />

  <!-- Difference -->
  <section class="section surface-night-forest">
    <div class="container diff">
      <div class="diff__media">
        <img
          src="/images/relume-653351.jpeg"
          srcset="/images/relume-653351-p-500.jpeg 500w, /images/relume-653351-p-800.jpeg 800w, /images/relume-653351-p-1080.jpeg 1080w, /images/relume-653351-p-1600.jpeg 1600w, /images/relume-653351.jpeg 1920w"
          sizes="(max-width: 900px) 90vw, 45vw"
          alt="Hand in work glove adjusting yellow and metallic plumbing valves"
          loading="lazy"
        />
      </div>
      <div class="diff__content">
        <span class="eyebrow">Difference</span>
        <h2>Licensed master plumber with gas certification</h2>
        <p class="lead">Over a decade in the trade means every job gets done to code. Your plumbing is built to last.</p>
        <div class="btn-group">
          <a href={business.bookingUrl} class="btn btn--gold"><Icon name="calendar" /> Book Appointment</a>
          <a href={business.primaryPhoneTel} class="btn btn--forest"><Icon name="phone" /> Call</a>
        </div>
        <div class="diff__cards">
          <div class="diff__card">
            <h3>Precision matters</h3>
            <p>Hidden or visible, we treat every connection with the same care and attention to detail.</p>
          </div>
          <div class="diff__card">
            <h3>You understand the work</h3>
            <p>We walk you through the process so you know exactly what was done and why it matters.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What we handle (feature cards) -->
  <section class="section surface-night">
    <div class="container">
      <div class="section-head is-center wh__head">
        <span class="eyebrow">Services</span>
        <h2>What we handle</h2>
        <p class="lead">From burst pipes to complete installations</p>
      </div>
      <div class="wh__grid">
        <ServiceCard
          variant="dark"
          title="Plumbing emergencies don't wait"
          href="/emergency-plumber-merrimack-nh"
          eyebrow="Emergency"
          body="We answer the phone and come fast"
          image="/images/relume-653255.jpeg"
          imageSrcset="/images/relume-653255-p-500.jpeg 500w, /images/relume-653255-p-800.jpeg 800w, /images/relume-653255-p-1080.jpeg 1080w, /images/relume-653255-p-1600.jpeg 1600w, /images/relume-653255.jpeg 1920w"
          imageAlt="Shocked woman looking at water leaking from ceiling into blue bucket"
        />
        <ServiceCard
          variant="dark"
          title="Water heaters and filtration systems"
          href="/water-heater-installation-merrimack-nh"
          eyebrow="Water"
          body="Installation and repair when you need it"
          image="/images/relume-653257.jpeg"
          imageSrcset="/images/relume-653257-p-500.jpeg 500w, /images/relume-653257-p-800.jpeg 800w, /images/relume-653257-p-1080.jpeg 1080w, /images/relume-653257-p-1600.jpeg 1600w, /images/relume-653257.jpeg 1920w"
          imageAlt="Technician checking electrical settings on Grundfos pump control panel"
        />
      </div>
    </div>
  </section>

  <!-- SEO services grid -->
  <section class="section surface-night">
    <div class="container">
      <div class="seo-top">
        <div class="seo-top__lead">
          <span class="eyebrow">Our services</span>
          <h2>Plumbing Services in Merrimack, NH (and Surrounding Areas)</h2>
          <p>Pine Valley Plumbing provides residential plumbing repair, installation, and emergency service in Merrimack, New Hampshire and nearby communities. Use the links below to explore each service, or call for a fast quote.</p>
          <div class="btn-group">
            <a class="btn btn--outline btn--sm" href={business.primaryPhoneTel}>{business.primaryPhone}</a>
            <a class="btn btn--outline btn--sm" href="/plumbing-services-in-hillsborough-county">Hillsborough County Service Area</a>
          </div>
          <p class="seo-fine">Looking for a licensed master plumber with gas certification? We handle urgent repairs, upgrades, remodel plumbing, and preventative protection.</p>
        </div>
        <div class="seo-badges">
          {serviceBadges.map((b) => <span class="seo-badge">{b}</span>)}
        </div>
      </div>

      <div class="seo-grid">
        {seoServices.map(([h, p, link, href, icon, img]) => (
          <a class="seo-card" href={href}>
            <div class="seo-card__media">
              <img
                src={`/images/${img}.jpeg`}
                srcset={`/images/${img}-p-500.jpeg 500w, /images/${img}-p-800.jpeg 800w`}
                sizes="(max-width: 560px) 90vw, (max-width: 900px) 45vw, 400px"
                alt=""
                loading="lazy"
              />
            </div>
            <div class="seo-card__body">
              <span class="icon-chip seo-card__chip"><Icon name={icon} /></span>
              <h3>{h}</h3>
              <p>{p}</p>
              <span class="link-arrow seo-card__link">{link} <Icon name="arrow-right" /></span>
            </div>
          </a>
        ))}
      </div>

      <div class="seo-mini">
        <div class="seo-box">
          <span class="icon-chip"><Icon name="wrench" /></span>
          <h3>Common Plumbing Problems We Solve</h3>
          <ul class="check-list">
            <li><Icon name="check" /> Leaks under sinks, behind walls, and at fixtures</li>
            <li><Icon name="check" /> Slow drains, backups, odors, and recurring clogs</li>
            <li><Icon name="check" /> No hot water, temperature swings, pilot/ignition issues</li>
            <li><Icon name="check" /> Low water pressure and failing shutoff valves</li>
            <li><Icon name="check" /> Plumbing support for kitchen & bathroom upgrades</li>
          </ul>
        </div>
        <div class="seo-box">
          <span class="icon-chip"><Icon name="map-pin" /></span>
          <h3>Service Area</h3>
          <p>Based in Merrimack, NH — serving surrounding areas in the region, including Nashua, Amherst, and Hillsborough County.</p>
          <p class="seo-fine">Call <a href="tel:+16033396732">(603) 339-6732</a> or email <a href="mailto:priorityplumbingnh@gmail.com">priorityplumbingnh@gmail.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Careers -->
  <section class="section surface-night careers-cta">
    <div class="container">
      <div class="careers-cta__panel card-dark card-dark--leaf">
        <div class="careers-cta__inner">
          <div>
            <span class="eyebrow">Careers</span>
            <h2>More Than Just Plumbing</h2>
          </div>
          <div class="careers-cta__copy">
            <p class="lead">We don’t just serve our community — we’re part of it. By building strong careers for our team, we attract skilled professionals who take pride in their work and treat every home with care. When our people are supported, our customers feel the difference.</p>
            <p>Founded by a husband-and-wife team, Pine Valley Plumbing is built on communication, respect, and doing the job right the first time.</p>
            <div class="btn-group"><a href="/careers" class="btn btn--gold">Careers</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhood reviews widget (Real Work Labs) -->
  <section class="section surface-night">
    <div class="container">
      <RealWorkLabs outputId="rwl-neighborhood" />
    </div>
  </section>

  <FaqAccordion variant="dark" faqs={faqs} heading="FAQs" subheading="Questions about our services and process" />

  <section class="section--sm section surface-night">
    <div class="container--md container text-center">
      <h3>More questions?</h3>
      <p class="lead" style="margin-top:.75rem">Reach out and we'll answer what you need to know.</p>
      <div class="btn-group is-center" style="margin-top:1.25rem">
        <a href={business.primaryPhoneTel} class="btn btn--forest"><Icon name="phone" /> Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* About (dark) */
  .about-dark { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
  .about-dark__content > * + * { margin-top: 1.1rem; }
  .about-dark__media img {
    width: 100%;
    border-radius: var(--radius-xl);
    border: 1px solid #ffffff2e;
    box-shadow: var(--shadow-night);
    aspect-ratio: 16/10;
    object-fit: cover;
  }
  .about-dark__list {
    list-style: none;
    display: grid;
    gap: 0.7rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--on-night-strong);
  }
  .about-dark__list li { display: grid; grid-template-columns: 1.5rem 1fr; gap: 0.65rem; align-items: center; }
  .about-dark__check {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--leaf-500);
    color: var(--night-950);
  }
  .about-dark__check :global(svg) { width: 0.9rem; height: 0.9rem; }

  /* Difference */
  .diff { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
  .diff__media img {
    width: 100%;
    border-radius: var(--radius-xl);
    border: 1px solid #ffffff2e;
    box-shadow: var(--shadow-night);
    aspect-ratio: 4/3;
    object-fit: cover;
  }
  .diff__content > * + * { margin-top: 1.1rem; }
  .diff__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.75rem; }
  .diff__card { background: var(--night-900); border: 1px solid var(--border-gold-soft); border-radius: var(--radius-md); padding: 1.25rem; }
  .diff__card h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .diff__card p { color: var(--on-night-body); }

  /* Careers */
  .careers-cta__panel { padding: clamp(1.75rem, 4vw, 3rem); }
  .careers-cta__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
  .careers-cta h2 { font-size: var(--fs-h2); }
  .careers-cta__copy > * + * { margin-top: 1rem; }
  .careers-cta__copy p:not(.lead) { color: var(--on-night-muted); }

  /* What we handle */
  .wh__head { margin-bottom: 2.5rem; }
  .wh__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; }

  /* SEO block */
  .seo-top { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 1.5rem; align-items: start; margin-bottom: 2.5rem; }
  .seo-top h2 { font-size: var(--fs-h3); margin-bottom: 0.75rem; }
  .seo-top__lead .eyebrow { margin-bottom: 0.5rem; }
  .seo-top__lead .btn-group { margin-top: 1rem; }
  .seo-fine { font-size: var(--fs-body-sm); color: var(--on-night-muted); margin-top: 0.85rem; }
  .seo-badges { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: flex-end; }
  .seo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border-leaf-soft);
    background: transparent;
    color: var(--on-night-strong);
    border-radius: var(--radius-pill);
    padding: 0.5rem 0.95rem;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .seo-badge::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--color-gold); flex: none; }

  .seo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .seo-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    overflow: hidden;
    background: var(--night-900);
    border: 1px solid var(--border-gold-soft);
    border-top: 4px solid var(--gold-500);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-night);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .seo-card:hover { transform: translateY(-4px); border-color: var(--gold-500); }
  .seo-card__media { aspect-ratio: 16 / 9; width: 100%; }
  .seo-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .seo-card:hover .seo-card__media img { filter: brightness(1.08); }
  .seo-card__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: 1;
    padding: 0 1.4rem 1.5rem;
  }
  .seo-card h3 { font-size: 1.2rem; margin-bottom: 0.3rem; }
  .seo-card p { font-size: var(--fs-body-sm); color: var(--on-night-muted); margin-bottom: 0.9rem; flex: 1; }
  .seo-card__link { margin-top: auto; }
  .seo-card:hover .seo-card__link :global(svg) { transform: translateX(4px); }

  .seo-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.5rem; }
  .seo-box {
    background: var(--night-900);
    border: 1px solid var(--border-gold-soft);
    border-top: 4px solid var(--leaf-600);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-night);
  }
  .seo-box .icon-chip { margin-bottom: 0.9rem; }
  .seo-box h3 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .seo-box .seo-fine a { color: var(--leaf-500); font-weight: 700; }

  /* green-glow icon chips on the dark cards (overrides the light global chip) */
  .seo-mini .icon-chip { background: #3cb44a1f; color: var(--leaf-500); }
  /* card chips sit half over the photo, so they need a solid fill */
  .seo-grid .icon-chip {
    background: var(--night-900);
    border: 1px solid var(--border-leaf-soft);
    color: var(--leaf-500);
    margin-top: -1.5rem;
    margin-bottom: 0.9rem;
  }

  @media (max-width: 900px) {
    .diff, .careers-cta__inner, .about-dark { grid-template-columns: 1fr; }
    .diff__media { max-width: 32rem; margin-inline: auto; }
    .wh__grid { grid-template-columns: 1fr; }
    .seo-top { grid-template-columns: 1fr; }
    .seo-badges { justify-content: flex-start; }
    .seo-grid { grid-template-columns: 1fr 1fr; }
    .seo-mini { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .diff__cards, .seo-grid { grid-template-columns: 1fr; }
  }
</style>
