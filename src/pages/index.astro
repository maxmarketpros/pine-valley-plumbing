---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import TrustBadges from "../components/TrustBadges.astro";
import Testimonials from "../components/Testimonials.astro";
import CtaBand from "../components/CtaBand.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Seal from "../components/Seal.astro";
import Icon from "../components/Icon.astro";
import RealWorkLabs from "../components/RealWorkLabs.astro";
import { business, services as allServices } from "../data/site";

const title = "Expert Master Plumber in Merrimack, NH | Pine Valley Plumbing";
const description =
  "Choose Pine Valley Plumbing for trusted, expert plumbing services in Merrimack, NH. We handle emergencies and installations with care and precision.";

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Pine Valley Plumbing",
  description:
    "Licensed master plumber serving Merrimack, NH and surrounding areas with emergency repairs, installations, and complete plumbing services. Over a decade of expertise with gas certification.",
  url: "https://hirepinevalley.com/",
  telephone: "(603) 521-2433",
  email: "priorityplumbingnh@gmail.com",
  address: { "@type": "PostalAddress", addressLocality: "Merrimack", addressRegion: "NH", addressCountry: "US" },
  areaServed: [
    { "@type": "City", name: "Merrimack", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Manchester", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Nashua", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Derry", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Salem", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Bedford", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Londonderry", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "City", name: "Amherst", containedInPlace: { "@type": "State", name: "New Hampshire" } },
    { "@type": "AdministrativeArea", name: "Hillsborough County", containedInPlace: { "@type": "State", name: "New Hampshire" } },
  ],
  priceRange: "$$",
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "132", bestRating: "5" },
  sameAs: ["https://share.google/uo5SvDFsKKNNTtAn0"],
  openingHours: "Mo-Su 00:00-23:59",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Plumbing Services",
    itemListElement: [
      ["Emergency Plumbing Services", "24/7 emergency plumbing repairs and service"],
      ["Drain Cleaning Services", "Professional drain cleaning and maintenance"],
      ["Water Heater Installation", "Complete water heater installation services"],
      ["Water Heater Repair", "Expert water heater repair and maintenance"],
      ["Faucet Repair Services", "Professional faucet repair and replacement"],
      ["Kitchen Plumbing Services", "Complete kitchen plumbing solutions"],
      ["Gas Line Services", "Licensed gas line installation and repair"],
      ["Toilet Installation Services", "Professional toilet installation and replacement"],
      ["Garbage Disposal Installation", "Expert garbage disposal installation"],
      ["Pipe Repair Services", "Professional pipe repair and replacement"],
      ["Water & Flood Prevention Systems", "Sump pump and backflow prevention systems"],
    ].map(([name, d]) => ({ "@type": "Offer", itemOffered: { "@type": "Service", name, description: d } })),
  },
};

const SITE = "https://hirepinevalley.com";
const plumberSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: "Pine Valley Plumbing",
  url: `${SITE}/`,
  telephone: "+1-603-521-2433",
  email: "priorityplumbingnh@gmail.com",
  areaServed: [
    { "@type": "City", name: "Merrimack" },
    { "@type": "AdministrativeArea", name: "Hillsborough County" },
    { "@type": "AdministrativeArea", name: "New Hampshire" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Plumbing Services",
    itemListElement: [
      ["Emergency Plumbing Services", "/emergency-plumber-merrimack-nh"],
      ["Drain Cleaning Services", "/drain-cleaning-merrimack-nh"],
      ["Water Heater Installation", "/water-heater-installation-merrimack-nh"],
      ["Water Heater Repair", "/water-heater-repair-merrimack-nh"],
      ["Faucet Repair Services", "/faucet-repair-merrimack-nh"],
      ["Kitchen Plumbing Services", "/kitchen-plumbing-merrimack-nh"],
      ["Bathroom Remodeling Services", "/bathroom-remodeling-merrimack-nh"],
      ["Gas Line Services", "/gas-line-services-merrimack-nh"],
      ["Toilet Installation Services", "/toilet-installation-merrimack-nh"],
      ["Garbage Disposal Installation", "/garbage-disposal-installation-merrimack-nh"],
      ["Pipe Repair Services", "/pipe-repair-merrimack-nh"],
      ["Water & Flood Prevention Systems", "/sump-pump-backflow-merrimack-nh"],
    ].map(([name, path]) => ({ "@type": "Offer", itemOffered: { "@type": "Service", name, url: `${SITE}${path}` } })),
  },
};

const marqueeItems = [
  "Fast service", "Expert work", "Licensed master", "Gas certified", "Honest pricing",
  "Done right", "No shortcuts", "Visible care", "Hidden precision", "Always available",
];

const testimonials = [
  { quote: "Fast, professional, and honest.", location: "Merrimack, NH" },
  { quote: "Showed up on time and did great work.", location: "Bedford, NH" },
  { quote: "Best plumbing company we've used.", location: "Nashua, NH" },
];

// SEO services grid (matches source "pv-seo" block)
const seoServices = [
  ["Emergency Plumbing", "Burst pipes, backups, no hot water—call anytime for fast help.", "Emergency Plumbing Services", "/emergency-plumber-merrimack-nh", "phone"],
  ["Drain Cleaning", "Clear clogs the right way—no shortcuts, no pipe damage.", "Drain Cleaning Services", "/drain-cleaning-merrimack-nh", "droplet"],
  ["Water Heater Installation", "New tank or tankless systems installed cleanly, safely, and to code.", "Water Heater Installation", "/water-heater-installation-merrimack-nh", "flame"],
  ["Water Heater Repair", "Diagnostics + real repairs so you’re not stuck with cold showers.", "Water Heater Repair", "/water-heater-repair-merrimack-nh", "thermometer"],
  ["Gas Line Services", "Gas piping work done by a certified professional—safety first.", "Gas Line Services", "/gas-line-services-merrimack-nh", "shield-check"],
  ["Pipe Repair & Leak Fixes", "Stop leaks, protect your home, and prevent bigger failures.", "Pipe Repair Services", "/pipe-repair-merrimack-nh", "wrench"],
  ["Kitchen Plumbing", "Faucets, sinks, dishwasher hookups, and kitchen upgrades done right.", "Kitchen Plumbing Services", "/kitchen-plumbing-merrimack-nh", "utensils"],
  ["Bathroom Remodeling", "Remodel plumbing for showers, tubs, toilets, and full bathroom upgrades.", "Bathroom Remodeling Services", "/bathroom-remodeling-merrimack-nh", "shower-head"],
  ["Toilet Installation", "New installs or replacements—sealed, leveled, and tested.", "Toilet Installation Services", "/toilet-installation-merrimack-nh", "droplet"],
  ["Garbage Disposal Installation", "Clean installs with proper connections and leak checks.", "Garbage Disposal Installation", "/garbage-disposal-installation-merrimack-nh", "trash"],
  ["Flood Prevention", "Sump pumps & backflow protection to help keep basements dry.", "Water & Flood Prevention Systems", "/sump-pump-backflow-merrimack-nh", "waves"],
];

const serviceBadges = ["Emergency Response", "Drain & Sewer Issues", "Water Heaters", "Gas Line Services", "Remodel Plumbing", "Leak & Pipe Repair"];

const faqs = [
  { q: "Do you offer emergency service?", a: "Yes. We handle emergency plumbing calls and come as fast as we can. Call (603) 339-6732 anytime you need us. We understand that plumbing problems don't follow business hours." },
  { q: "What areas do you service?", a: "We're based in Merrimack, New Hampshire and service the surrounding areas. That includes Nashua, Amherst, Hillsborough County, and beyond. Call to confirm we reach your location." },
  { q: "Are you licensed?", a: "I'm a master plumber with a gas license. Thirteen years in the trade and every job meets code. You can trust the work is done right." },
  { q: "Why take so much time?", a: "Rushing leads to problems. We do it right the first time, whether it's visible or hidden in the walls. That's how I was taught and that's how we work." },
];
---

<BaseLayout title={title} description={description} bodyClass="page-home" jsonLd={[localBusiness, plumberSchema]}>
  <Hero
    heading='Plumber in <span class="hl">Merrimack, NH</span>'
    subheading="Pine Valley Plumbing serves Merrimack, New Hampshire and the surrounding areas with honest work and real expertise. We handle everything from emergency repairs to complete system installations, and we take the time to do it correctly."
    image="/images/relume-653201.jpeg"
    imageSrcset="/images/relume-653201-p-500.jpeg 500w, /images/relume-653201-p-800.jpeg 800w, /images/relume-653201-p-1080.jpeg 1080w, /images/relume-653201-p-1600.jpeg 1600w, /images/relume-653201.jpeg 1920w"
    imageAlt="Plumber fixing sink pipe with wrench under kitchen sink"
  />

  <Marquee items={marqueeItems} />

  <TrustBadges />

  <!-- Difference -->
  <section class="section surface-forest">
    <div class="container diff">
      <div class="diff__media">
        <img
          src="/images/relume-653351.jpeg"
          srcset="/images/relume-653351-p-500.jpeg 500w, /images/relume-653351-p-800.jpeg 800w, /images/relume-653351-p-1080.jpeg 1080w, /images/relume-653351-p-1600.jpeg 1600w, /images/relume-653351.jpeg 1920w"
          sizes="(max-width: 900px) 90vw, 45vw"
          alt="Hand in work glove adjusting yellow and metallic plumbing valves"
          loading="lazy"
        />
      </div>
      <div class="diff__content">
        <span class="eyebrow">Difference</span>
        <h2>Licensed master plumber with gas certification</h2>
        <p class="lead">Over a decade in the trade means every job gets done to code. Your plumbing is built to last.</p>
        <div class="btn-group">
          <a href={business.bookingUrl} class="btn btn--gold"><Icon name="calendar" /> Book Appointment</a>
          <a href={business.primaryPhoneTel} class="btn btn--outline"><Icon name="phone" /> Call</a>
        </div>
        <div class="diff__cards">
          <div class="diff__card">
            <h3>Precision matters</h3>
            <p>Hidden or visible, we treat every connection with the same care and attention to detail.</p>
          </div>
          <div class="diff__card">
            <h3>You understand the work</h3>
            <p>We walk you through the process so you know exactly what was done and why it matters.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials items={testimonials} />

  <!-- Careers -->
  <section class="section surface-wood careers-cta">
    <div class="container careers-cta__inner">
      <div>
        <span class="eyebrow">Careers</span>
        <h2>More Than Just Plumbing</h2>
      </div>
      <div>
        <p class="lead">We don’t just serve our community — we’re part of it. By building strong careers for our team, we attract skilled professionals who take pride in their work and treat every home with care. When our people are supported, our customers feel the difference.</p>
        <div class="btn-group"><a href="/careers" class="btn btn--gold">Careers</a></div>
      </div>
    </div>
  </section>

  <!-- About / Go-to plumber -->
  <section class="section surface-cream">
    <div class="container about-home">
      <div class="about-home__content">
        <span class="eyebrow">Background</span>
        <h2>More Than Just Plumbing</h2>
        <p>Pine Valley Plumbing was founded by a husband-and-wife team who believe great service is about more than fixing a problem - it's about communication, respect, and doing the job right the first time. <br />With over a decade of experience in residential and commercial plumbing, our work is rooted in craftsmanship, code compliance, and long-term solutions. Paired with a strong background in design and customer experience, we focus on making the entire process clear, comfortable, and stress-free for our customers.</p>
        <div class="btn-group"><a href="/about-pine-valley-plumbing-merrimack-nh" class="btn btn--green">About</a></div>
      </div>
      <div class="about-home__media">
        <img
          src="/images/relume-653251.jpeg"
          srcset="/images/relume-653251-p-500.jpeg 500w, /images/relume-653251-p-800.jpeg 800w, /images/relume-653251-p-1080.jpeg 1080w, /images/relume-653251-p-1600.jpeg 1600w, /images/relume-653251.jpeg 1920w"
          sizes="(max-width: 900px) 90vw, 45vw"
          alt="Hands tightening plumbing pipe connection with metallic background"
          loading="lazy"
        />
        <Seal class="about-home__seal" />
      </div>
    </div>
  </section>

  <!-- What we handle (feature cards) -->
  <section class="section surface-forest">
    <div class="container">
      <div class="section-head is-center wh__head">
        <span class="eyebrow">Services</span>
        <h2>What we handle</h2>
        <p class="lead">From burst pipes to complete installations</p>
      </div>
      <div class="wh__grid">
        <ServiceCard
          title="Plumbing emergencies don't wait"
          href="/emergency-plumber-merrimack-nh"
          eyebrow="Emergency"
          body="We answer the phone and come fast"
          image="/images/relume-653255.jpeg"
          imageSrcset="/images/relume-653255-p-500.jpeg 500w, /images/relume-653255-p-800.jpeg 800w, /images/relume-653255-p-1080.jpeg 1080w, /images/relume-653255-p-1600.jpeg 1600w, /images/relume-653255.jpeg 1920w"
          imageAlt="Shocked woman looking at water leaking from ceiling into blue bucket"
        />
        <ServiceCard
          title="Water heaters and filtration systems"
          href="/water-heater-installation-merrimack-nh"
          eyebrow="Water"
          body="Installation and repair when you need it"
          image="/images/relume-653257.jpeg"
          imageSrcset="/images/relume-653257-p-500.jpeg 500w, /images/relume-653257-p-800.jpeg 800w, /images/relume-653257-p-1080.jpeg 1080w, /images/relume-653257-p-1600.jpeg 1600w, /images/relume-653257.jpeg 1920w"
          imageAlt="Technician checking electrical settings on Grundfos pump control panel"
        />
      </div>
    </div>
  </section>

  <!-- SEO services grid -->
  <section class="section surface-cream">
    <div class="container">
      <div class="seo-top">
        <div class="seo-top__lead">
          <span class="eyebrow">Our services</span>
          <h2>Plumbing Services in Merrimack, NH (and Surrounding Areas)</h2>
          <p>Pine Valley Plumbing provides residential plumbing repair, installation, and emergency service in Merrimack, New Hampshire and nearby communities. Use the links below to explore each service, or call for a fast quote.</p>
          <div class="btn-group">
            <a class="btn btn--outline btn--sm" href={business.primaryPhoneTel}>{business.primaryPhone}</a>
            <a class="btn btn--outline btn--sm" href="/plumbing-services-in-hillsborough-county">Hillsborough County Service Area</a>
          </div>
          <p class="seo-fine">Looking for a licensed master plumber with gas certification? We handle urgent repairs, upgrades, remodel plumbing, and preventative protection.</p>
        </div>
        <div class="seo-badges">
          {serviceBadges.map((b) => <span class="seo-badge">{b}</span>)}
        </div>
      </div>

      <div class="seo-grid">
        {seoServices.map(([h, p, link, href, icon]) => (
          <a class="seo-card" href={href}>
            <span class="icon-chip seo-card__chip"><Icon name={icon} /></span>
            <h3>{h}</h3>
            <p>{p}</p>
            <span class="link-arrow seo-card__link">{link} <Icon name="arrow-right" /></span>
          </a>
        ))}
      </div>

      <div class="seo-mini">
        <div class="seo-box">
          <span class="icon-chip"><Icon name="wrench" /></span>
          <h3>Common Plumbing Problems We Solve</h3>
          <ul class="check-list">
            <li><Icon name="check" /> Leaks under sinks, behind walls, and at fixtures</li>
            <li><Icon name="check" /> Slow drains, backups, odors, and recurring clogs</li>
            <li><Icon name="check" /> No hot water, temperature swings, pilot/ignition issues</li>
            <li><Icon name="check" /> Low water pressure and failing shutoff valves</li>
            <li><Icon name="check" /> Plumbing support for kitchen & bathroom upgrades</li>
          </ul>
        </div>
        <div class="seo-box">
          <span class="icon-chip"><Icon name="map-pin" /></span>
          <h3>Service Area</h3>
          <p>Based in Merrimack, NH — serving surrounding areas in the region, including Nashua, Amherst, and Hillsborough County.</p>
          <p class="seo-fine">Call <a href="tel:+16035212433">(603) 521-2433</a> or email <a href="mailto:priorityplumbingnh@gmail.com">priorityplumbingnh@gmail.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhood reviews widget (Real Work Labs) -->
  <section class="section surface-paper">
    <div class="container">
      <RealWorkLabs outputId="rwl-neighborhood" />
    </div>
  </section>

  <CtaBand
    heading="Ready to get started"
    body="Call for emergency service or a free estimate on your project."
  />

  <FaqAccordion faqs={faqs} heading="FAQs" subheading="Questions about our services and process" />

  <section class="section--sm section surface-cream">
    <div class="container--md container text-center">
      <h3>More questions?</h3>
      <p class="lead" style="margin-top:.75rem">Reach out and we'll answer what you need to know.</p>
      <div class="btn-group is-center" style="margin-top:1.25rem">
        <a href={business.primaryPhoneTel} class="btn btn--green"><Icon name="phone" /> Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* home hero uses the marker font */
  :global(.page-home) .hero__heading {
    font-family: var(--font-hero);
    letter-spacing: 0;
    line-height: 1.05;
  }

  /* Difference */
  .diff { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
  .diff__media img { width: 100%; border-radius: var(--radius-xl); border: 5px solid var(--cream-100); box-shadow: var(--shadow-hover); transform: rotate(-1.4deg); aspect-ratio: 4/3; object-fit: cover; }
  .diff__content > * + * { margin-top: 1.1rem; }
  .diff__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.75rem; }
  .diff__card { background: #ffffff14; border: 1px solid #ffffff26; border-radius: var(--radius-md); padding: 1.25rem; }
  .diff__card h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .diff__card p { color: var(--on-forest-body); }

  /* Careers */
  .careers-cta__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
  .careers-cta h2 { font-size: var(--fs-h2); }

  /* About */
  .about-home { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
  .about-home__content > * + * { margin-top: 1.1rem; }
  .about-home__media { position: relative; }
  .about-home__media img { width: 100%; border-radius: var(--radius-xl); box-shadow: var(--shadow-hover); aspect-ratio: 4/3; object-fit: cover; }
  .about-home__seal { position: absolute; right: -14px; bottom: -28px; width: 130px; height: 130px; background: var(--cream-100); border-radius: 50%; padding: 6px; box-shadow: var(--shadow-card); }

  /* What we handle */
  .wh__head { margin-bottom: 2.5rem; }
  .wh__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; }

  /* SEO block */
  .seo-top { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 1.5rem; align-items: start; margin-bottom: 2.5rem; }
  .seo-top h2 { font-size: var(--fs-h3); margin-bottom: 0.75rem; }
  .seo-top__lead .eyebrow { margin-bottom: 0.5rem; }
  .seo-top__lead .btn-group { margin-top: 1rem; }
  .seo-fine { font-size: var(--fs-body-sm); color: var(--on-cream-muted); margin-top: 0.85rem; }
  .seo-badges { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: flex-end; }
  .seo-badge { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid #00000018; background: #fff; border-radius: var(--radius-pill); padding: 0.5rem 0.95rem; font-size: 0.85rem; font-weight: 700; box-shadow: var(--shadow-card); }
  .seo-badge::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--color-gold); flex: none; }

  .seo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .seo-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    background: #fff;
    border: 1px solid #00000010;
    border-top: 4px solid var(--gold-500);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.4rem;
    box-shadow: var(--shadow-card);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .seo-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .seo-card__chip { margin-bottom: 0.9rem; }
  .seo-card h3 { font-size: 1.2rem; margin-bottom: 0.3rem; }
  .seo-card p { font-size: var(--fs-body-sm); color: var(--on-cream-muted); margin-bottom: 0.9rem; flex: 1; }
  .seo-card__link { margin-top: auto; }
  .seo-card:hover .seo-card__link :global(svg) { transform: translateX(4px); }

  .seo-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 1.5rem; }
  .seo-box { background: #fff; border: 1px solid #00000010; border-top: 4px solid var(--color-green-deep); border-radius: var(--radius-lg); padding: 1.75rem; box-shadow: var(--shadow-card); }
  .seo-box .icon-chip { margin-bottom: 0.9rem; }
  .seo-box h3 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .seo-box .seo-fine a { color: var(--color-green-deep); font-weight: 700; }

  @media (max-width: 900px) {
    .diff, .careers-cta__inner, .about-home { grid-template-columns: 1fr; }
    .diff__media { max-width: 32rem; margin-inline: auto; }
    .wh__grid { grid-template-columns: 1fr; }
    .seo-top { grid-template-columns: 1fr; }
    .seo-badges { justify-content: flex-start; }
    .seo-grid { grid-template-columns: 1fr 1fr; }
    .seo-mini { grid-template-columns: 1fr; }
    .about-home__seal { width: 104px; height: 104px; right: 8px; bottom: -22px; }
  }
  @media (max-width: 560px) {
    .diff__cards, .seo-grid { grid-template-columns: 1fr; }
  }
</style>
