---
/**
 * Inline SVG icon set. Stroke icons inherit `currentColor`.
 * Usage: <Icon name="phone" /> ; size via font-size / width on parent or `size` prop.
 */
interface Props {
  name: string;
  size?: string | number;
  class?: string;
  title?: string;
}
const { name, size, class: className, title } = Astro.props;

type IconDef = { viewBox?: string; type?: "stroke" | "fill"; body: string };

