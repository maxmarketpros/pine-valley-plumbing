  youtube: { type: "fill", body: `<path fill-rule="evenodd" clip-rule="evenodd" d="M20.5686 4.77345C21.5163 5.02692 22.2555 5.76903 22.5118 6.71673C23.1821 9.42042 23.1385 14.5321 22.5259 17.278C22.2724 18.2257 21.5303 18.965 20.5826 19.2213C17.9071 19.8831 5.92356 19.8015 3.40294 19.2213C2.45524 18.9678 1.71595 18.2257 1.45966 17.278C0.827391 14.7011 0.871044 9.25144 1.44558 6.73081C1.69905 5.78311 2.44116 5.04382 3.38886 4.78753C6.96561 4.0412 19.2956 4.282 20.5686 4.77345ZM9.86682 8.70227L15.6122 11.9974L9.86682 15.2925V8.70227Z"/>` },
};

const def = icons[name];
const viewBox = def?.viewBox ?? "0 0 24 24";
const isStroke = (def?.type ?? "stroke") === "stroke";
// Concrete default size (1em) so icons never balloon when component-scoped
// sizing CSS doesn't reach this child SVG; global/scoped CSS can still override.
const dim = size ? (typeof size === "number" ? `${size}px` : size) : "1em";
---

{def && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={viewBox}
    class={className}
    width={dim}
    height={dim}
    fill={isStroke ? "none" : "currentColor"}
    stroke={isStroke ? "currentColor" : undefined}
    stroke-width={isStroke ? 1.9 : undefined}
    stroke-linecap={isStroke ? "round" : undefined}
    stroke-linejoin={isStroke ? "round" : undefined}
    role={title ? "img" : undefined}
    aria-label={title}
    aria-hidden={title ? undefined : "true"}
    set:html={def.body}
  />
)}
