---
interface Props {
  eyebrow?: string;
  /** Heading HTML; wrap emphasis in <span class="hl">. */
  heading: string;
  lead?: string;
  scriptAccent?: string;
  align?: "center" | "left";
  class?: string;
}
const { eyebrow, heading, lead, scriptAccent, align = "center", class: className } = Astro.props;
---
<div class:list={["section-head", align === "center" && "is-center", className]}>
  {scriptAccent && <p class="script-accent">{scriptAccent}</p>}
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 set:html={heading} />
  {lead && <p class="lead">{lead}</p>}
</div>
