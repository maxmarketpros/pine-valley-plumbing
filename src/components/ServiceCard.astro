---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  href: string;
  body?: string;
  linkLabel?: string;
  eyebrow?: string;
  image?: string;
  imageAlt?: string;
  imageSrcset?: string;
}
const { title, href, body, linkLabel = "Learn more", eyebrow, image, imageAlt = "", imageSrcset } = Astro.props;
---

<a href={href} class="svc-card">
  {image && (
    <div class="svc-card__media">
      <img src={image} srcset={imageSrcset} sizes="(max-width: 700px) 90vw, 420px" alt={imageAlt} loading="lazy" />
    </div>
  )}
  <div class="svc-card__body">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h3 class="svc-card__title">{title}</h3>
    {body && <p class="svc-card__text">{body}</p>}
    <span class="link-arrow svc-card__link">{linkLabel} <Icon name="arrow-right" /></span>
  </div>
</a>

<style>
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid #00000010;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .svc-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .svc-card__media { aspect-ratio: 16 / 10; overflow: hidden; }
  .svc-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .svc-card__body { padding: var(--space-5); display: flex; flex-direction: column; gap: 0.6rem; flex: 1; }
  .svc-card__title { font-size: 1.4rem; color: var(--ink-900); }
  .svc-card__text { color: var(--on-cream-muted); font-size: var(--fs-body-sm); flex: 1; }
  .svc-card__link { margin-top: 0.5rem; }
</style>
