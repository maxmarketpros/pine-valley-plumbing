---
import Icon from "./Icon.astro";

interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  faqs: FaqItem[];
  heading?: string;
  subheading?: string;
  /** "dark" renders the night theme (homepage); default keeps the cream look. */
  variant?: "light" | "dark";
}
const { faqs, heading = "FAQs", subheading, variant = "light" } = Astro.props;
---

<section class:list={["faq", "section", variant === "dark" ? "surface-night faq--dark" : "surface-cream"]}>
  <div class="container--md container">
    {heading && (
      <div class="section-head is-center faq__head">
        <h2>{heading}</h2>
        {subheading && <p class="lead">{subheading}</p>}
      </div>
    )}
    <div class="faq__list">
      {faqs.map((item) => (
        <details class="faq__item">
          <summary class="faq__q">
            <span>{item.q}</span>
            <Icon name="plus" class="faq__icon" />
          </summary>
          <div class="faq__a"><p>{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__head { margin-bottom: 2.5rem; }
  .faq__list { display: grid; gap: 0; }
  .faq__item { border-bottom: 1px solid #00000016; }
  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0;
    cursor: pointer;
    list-style: none;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--ink-900);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__icon {
    width: 1.4rem;
    height: 1.4rem;
    flex-shrink: 0;
    color: var(--color-green-deep);
    transition: transform 0.2s ease;
  }
  .faq__item[open] .faq__icon { transform: rotate(45deg); }
  .faq__a {
    padding: 0 0 1.25rem;
    color: var(--on-cream-muted);
    max-width: 60ch;
  }
  .faq__a p { line-height: 1.6; }

  /* night-theme variant (homepage) */
  .faq--dark .faq__item { border-bottom-color: #ffffff1a; }
  .faq--dark .faq__q { color: var(--on-night-strong); }
  .faq--dark .faq__icon { color: var(--gold-500); }
  .faq--dark .faq__a { color: var(--on-night-muted); }
</style>
