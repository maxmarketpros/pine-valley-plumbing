---
import Icon from "./Icon.astro";
import { business } from "../data/site";
/** Shared "Get in touch" block: 3 contact cards + Google map. */
---
<div class="contact-grid">
  <div class="contact-cards">
    <div class="contact-card">
      <span class="icon-chip"><Icon name="mail" /></span>
      <h3>Email</h3>
      <p>Send us a message</p>
      <a href={business.navEmailHref} class="link-arrow">{business.navEmail} <Icon name="arrow-right" /></a>
    </div>
    <div class="contact-card">
      <span class="icon-chip"><Icon name="phone" /></span>
      <h3>Phone</h3>
      <p>Call us anytime</p>
      <a href={business.navPhoneTel} class="link-arrow">{business.navPhone} <Icon name="arrow-right" /></a>
    </div>
    <div class="contact-card">
      <span class="icon-chip"><Icon name="map-pin" /></span>
      <h3>Service Area</h3>
      <p>Merrimack, NH and surrounding areas</p>
    </div>
  </div>
  <div class="contact-map">
    <iframe
      title="Map of Merrimack, NH service area"
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d154905.20975101952!2d-71.51504105!3d42.85090195!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e3b457a4d7e7d5%3A0xb76047805520e379!2sMerrimack%2C%20NH!5e1!3m2!1sen!2sus!4v1766435531879!5m2!1sen!2sus"
      width="100%"
      height="450"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"></iframe>
  </div>
</div>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 2.5rem;
    margin-top: 2.75rem;
    align-items: start;
  }
  .contact-cards { display: grid; gap: 1.25rem; }
  .contact-card {
    background: #fff;
    border: 1px solid #00000010;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.5rem;
  }
  .contact-card h3 { font-size: 1.25rem; margin: 0.85rem 0 0.35rem; color: var(--ink-900); }
  .contact-card p { color: var(--on-cream-muted); margin-bottom: 0.5rem; }
  .contact-map iframe { display: block; border-radius: var(--radius-lg); box-shadow: var(--shadow-card); }
  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
