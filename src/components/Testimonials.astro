---
import { business } from "../data/site";
import Icon from "./Icon.astro";

interface Testimonial {
  quote: string;
  location: string;
}
interface Props {
  items: Testimonial[];
  scriptAccent?: string;
  heading?: string;
}
const {
  items,
  scriptAccent = "Why homeowners choose",
  heading = "Pine Valley Plumbing",
} = Astro.props;
---

<section class="tm surface-cream section">
  <div class="container">
    <div class="section-head is-center tm__head">
      <p class="script-accent">{scriptAccent}</p>
      <h2 set:html={heading} />
      <p class="tm__proof">
        <Icon name="google" class="tm__g" title="Google" />
        <span class="tm__proof-text">{business.rating} Stars from {business.reviewCount}+ Customers</span>
        <span class="tm__proof-stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="star" />)}
        </span>
      </p>
    </div>

    <div class="tm__grid">
      {items.map((t) => (
        <figure class="tm__card card">
          <div class="tm__stars" aria-hidden="true">{Array.from({ length: 5 }).map(() => <Icon name="star" />)}</div>
          <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
          <figcaption>&ndash; {t.location}</figcaption>
        </figure>
      ))}
    </div>

    <div class="btn-group is-center tm__more">
      <a href={business.googleReviewUrl} target="_blank" rel="noopener" class="btn btn--outline">
        Read More Reviews on Google <Icon name="arrow-right" />
      </a>
    </div>
  </div>
</section>

<style>
  .tm__head { margin-bottom: 2.75rem; }
  .tm__head h2 {
    font-size: clamp(2.4rem, 5.5vw, 4.5rem);
    letter-spacing: 0.02em;
  }
  .tm__proof {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .tm__proof :global(.tm__g) { width: 1.6rem; height: 1.6rem; }
  .tm__proof-text {
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--ink-900);
  }
  .tm__proof-stars { display: inline-flex; gap: 2px; color: var(--gold-500); }
  .tm__proof-stars svg { width: 1.1rem; height: 1.1rem; }

  .tm__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }
  .tm__card {
    margin: 0;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.9rem;
  }
  .tm__stars { display: flex; gap: 3px; color: var(--gold-500); }
  .tm__stars svg { width: 1.2rem; height: 1.2rem; }
  .tm__card blockquote {
    font-size: 1.1rem;
    line-height: 1.5;
    font-weight: 600;
    color: var(--ink-900);
    flex: 1;
  }
  .tm__card figcaption {
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--gold-700);
  }

  .tm__more { margin-top: 2.25rem; }

  @media (max-width: 900px) {
    .tm__grid { grid-template-columns: 1fr; max-width: 26rem; margin-inline: auto; }
  }
</style>
