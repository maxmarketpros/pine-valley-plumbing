---
/**
 * Homepage-only hero: full-bleed truck photo vignetted into the dark night
 * theme (the one dark section on the otherwise bright homepage); on mobile
 * the photo sits in flow above the text so the whole truck is always
 * visible. Interior pages keep Hero.astro.
 */
import { business } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="home-hero surface-night">
  <picture class="home-hero__pic">
    <img
      class="home-hero__bg"
      src="/images/truck-hero-wide-p-1600.webp"
      srcset="/images/truck-hero-wide-p-500.webp 500w, /images/truck-hero-wide-p-800.webp 800w, /images/truck-hero-wide-p-1080.webp 1080w, /images/truck-hero-wide-p-1600.webp 1600w"
      sizes="100vw"
      width="1600"
      height="1200"
      alt="Pine Valley Plumbing truck parked on a sunny Merrimack, NH street"
      loading="eager"
      fetchpriority="high"
    />
  </picture>
  <div class="home-hero__scrim" aria-hidden="true"></div>

  <div class="container home-hero__inner">
    <div class="home-hero__content">
      <h1 class="home-hero__heading">
        <span class="home-hero__line">Merrimack's</span>
        <span class="home-hero__line home-hero__line--gold">Trusted</span>
        <span class="home-hero__line">Local Plumber</span>
      </h1>
      <span class="home-hero__rule" aria-hidden="true"></span>

      <p class="home-hero__sub">Fast Service. Upfront Pricing. {business.reviewCount}+ Five-Star Reviews.</p>

      <ul class="home-hero__bullets">
        <li>
          <span class="home-hero__check"><Icon name="check" /></span>
          Water heaters, well systems, drain issues, fixture repairs, and more.
        </li>
        <li>
          <span class="home-hero__check"><Icon name="check" /></span>
          Serving Merrimack and surrounding towns.
        </li>
      </ul>

      <div class="home-hero__proof">
        <Icon name="google" class="home-hero__g" title="Google" />
        <span class="home-hero__stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="star" />)}
        </span>
        <span class="home-hero__proof-text">{business.rating} Stars | {business.reviewCount} Google Reviews</span>
      </div>

      <p class="home-hero__licensed"><Icon name="shield-check" /> Licensed &amp; Insured</p>

      <div class="btn-group home-hero__buttons">
        <a href={business.primaryPhoneTel} class="btn btn--forest btn--xl">
          <Icon name="phone" />
          <span class="home-hero__btn-label">
            <span class="home-hero__btn-top">Call Now</span>
            <span class="home-hero__btn-main">{business.primaryPhone}</span>
          </span>
        </a>
        <a href={business.bookingUrl} class="btn btn--gold btn--xl">
          <Icon name="calendar" />
          <span class="home-hero__btn-label">
            <span class="home-hero__btn-main">Book Online</span>
            <span class="home-hero__btn-note">It's quick &amp; easy!</span>
          </span>
          <Icon name="arrow-right" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    /* ~2:1 section over a 4:3 photo keeps the whole truck in the cover crop */
    min-height: clamp(560px, 50vw, 1000px);
    display: grid;
    align-items: center;
  }
  .home-hero__pic {
    position: absolute;
    inset: 0;
  }
  .home-hero__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 55%;
  }
  .home-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, #081409f2 0%, #081409d9 32%, #08140966 58%, #08140914 80%, #0814090a 100%),
      linear-gradient(180deg, #08140973 0%, #0000 22%, #0000 70%, #081409 100%);
  }
  .home-hero__inner { position: relative; z-index: 1; padding-block: var(--section-md); }
  .home-hero__content { max-width: 34rem; }
  .home-hero__content > * + * { margin-top: 1.1rem; }

  .home-hero__heading {
    display: flex;
    flex-direction: column;
    font-size: var(--fs-h1);
    line-height: 0.98;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 24px #081409cc;
  }
  .home-hero__line { display: block; }
  .home-hero__line--gold {
    color: var(--gold-500);
    font-size: var(--fs-display-xl);
    line-height: 0.95;
  }
  .home-hero__rule {
    display: block;
    width: 180px;
    height: 3px;
    margin-top: 0.9rem;
    background: var(--gold-500);
    border-radius: 2px;
  }

  .home-hero__sub {
    font-size: var(--fs-body-lg);
    font-weight: 700;
    color: var(--on-night-strong);
  }

  .home-hero__bullets {
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }
  .home-hero__bullets li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.65rem;
    align-items: start;
    font-weight: 600;
    line-height: 1.45;
  }
  .home-hero__check {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-top: 0.05rem;
    border-radius: 50%;
    background: var(--gold-500);
    color: var(--night-950);
  }
  .home-hero__check svg { width: 0.9rem; height: 0.9rem; }

  .home-hero__proof {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .home-hero__g { width: 1.75rem; height: 1.75rem; }
  .home-hero__stars { display: inline-flex; gap: 2px; color: var(--gold-500); }
  .home-hero__stars svg { width: 1.15rem; height: 1.15rem; }
  .home-hero__proof-text {
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--on-night-strong);
  }

  .home-hero__licensed {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--on-night-strong);
  }
  .home-hero__licensed svg { width: 1.25rem; height: 1.25rem; color: var(--leaf-500); }

  .home-hero__buttons { margin-top: 1.6rem; }
  .home-hero :global(.btn--xl) {
    padding: 0.8rem 1.7rem;
    font-size: 1.05rem;
  }
  .home-hero__btn-label {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.15;
  }
  .home-hero__btn-top {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .home-hero__btn-main { font-size: 1.05em; }
  .home-hero__btn-note {
    font-family: var(--font-script);
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: none;
    letter-spacing: 0;
  }

  @media (max-width: 820px) {
    /* photo sits in flow above the text so the whole truck always shows */
    .home-hero {
      display: block;
      min-height: auto;
    }
    .home-hero__pic { position: relative; inset: auto; }
    /* native 4:3 ratio — the full photo shows, no crop */
    .home-hero__bg { aspect-ratio: 4 / 3; }
    /* blend the photo's bottom edge into the dark text panel below it */
    .home-hero__pic::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 22%;
      background: linear-gradient(180deg, #08140900 0%, #081409 100%);
      pointer-events: none;
    }
    .home-hero__scrim { display: none; }
    .home-hero__inner { padding-block: 1.9rem 2.75rem; }
  }
  @media (max-width: 560px) {
    .home-hero__buttons { flex-direction: column; align-items: stretch; }
    .home-hero__buttons .btn { width: 100%; }
  }
</style>
