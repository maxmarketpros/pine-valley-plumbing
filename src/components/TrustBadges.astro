---
import Icon from "./Icon.astro";

const badges = [
  { icon: "clock", label: "Same-Day Service Available" },
  { icon: "dollar-sign", label: "Upfront Flat-Rate Pricing" },
  { icon: "shield-check", label: "Licensed & Insured" },
  { icon: "home", label: "Locally Owned & Operated" },
  { icon: "credit-card", label: "Financing Available" },
];
---

<section class="trust surface-paper">
  <div class="container trust__row">
    {badges.map((b) => (
      <div class="trust__chip">
        <span class="trust__icon"><Icon name={b.icon} /></span>
        <span class="trust__label">{b.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    padding-block: 1.9rem;
    border-block: 1px solid #00000012;
  }
  .trust__row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }
  .trust__chip {
    display: grid;
    justify-items: center;
    align-content: start;
    text-align: center;
    gap: 0.65rem;
    padding-inline: 0.75rem;
  }
  .trust__chip + .trust__chip { border-left: 1px solid #00000014; }
  .trust__icon {
    display: grid;
    place-items: center;
    color: var(--leaf-600);
  }
  .trust__icon svg {
    width: 2.35rem;
    height: 2.35rem;
    stroke-width: 1.4;
  }
  .trust__label {
    font-weight: 800;
    font-size: 0.8rem;
    color: var(--ink-900);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.3;
    max-width: 9.5rem;
  }

  @media (max-width: 1023px) {
    .trust__row {
      grid-template-columns: repeat(3, 1fr);
      row-gap: 1.75rem;
    }
    .trust__chip + .trust__chip { border-left: 0; }
  }
  @media (max-width: 639px) {
    .trust__row { grid-template-columns: repeat(2, 1fr); row-gap: 1.5rem; }
    .trust__chip:last-child { grid-column: 1 / -1; }
  }
</style>
